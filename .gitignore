# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# ─────────────────────────────────────────────
# Data — raw .npy files can get large fast
# ─────────────────────────────────────────────
data/raw/*.npy
data/processed/*.npy
data/processed/*.npz

# Keep the folder structure in the repo
!data/raw/.gitkeep
!data/processed/.gitkeep

# Metadata CSV is tracked (it's small and useful)
# so data/raw/metadata.csv is NOT ignored

# ─────────────────────────────────────────────
# Models — binary, large, not version-controlled
# ─────────────────────────────────────────────
models/
logs/

# ─────────────────────────────────────────────
# MuJoCo
# ─────────────────────────────────────────────
*.mjb
*.mjcf.bak

# ─────────────────────────────────────────────
# OS clutter
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
# IDEs
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────────────
# Jupyter (if anyone experiments in notebooks)
# ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb